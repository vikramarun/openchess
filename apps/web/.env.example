# Web app environment (set these in Vercel → Project → Settings → Environment Variables).
# All are NEXT_PUBLIC_* — they are inlined into the client bundle at BUILD time,
# so set them before deploying (a change requires a redeploy).

# The deployed game server (the Rust chess-server — NOT on Vercel; host it on a
# VM / Fly / Railway / Render). Use https/wss in production.
NEXT_PUBLIC_SERVER_HTTP=https://your-game-server.example.com
NEXT_PUBLIC_SERVER_WS=wss://your-game-server.example.com

# WalletConnect Cloud project id (https://cloud.walletconnect.com). Without it,
# injected wallets (MetaMask) still work but WalletConnect pairing does not.
NEXT_PUBLIC_WC_PROJECT_ID=your_walletconnect_project_id
